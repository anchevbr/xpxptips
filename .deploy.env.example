DEPLOY_HOST=your.server.ip.or.host
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_APP_DIR=/root/ai-betting
DEPLOY_PM2_APP=ai-betting-bot

# Optional. If omitted, the script will use normal ssh/scp auth.
# DEPLOY_SSH_PASSWORD=your_vps_password

# Optional local override for a non-default config file path.
# DEPLOY_ENV_FILE=/absolute/path/to/.deploy.env