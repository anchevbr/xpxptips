# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GROUP_CHAT_ID=-100123456789
# Optional: fixed private operator chat for log forwarding. You can also
# subscribe dynamically by sending /start or /logs on to the bot in a private chat.
TELEGRAM_LOG_CHAT_ID=
TELEGRAM_LOG_LEVEL=info
TELEGRAM_LOG_BATCH_MS=15000

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_LIVE_CONTEXT_MODEL=gpt-5.4
OPENAI_COMMENTARY_MODEL=gpt-5.4
OPENAI_REPORT_MODEL=gpt-5.4
OPENAI_LIVE_CONTEXT_EFFORT=medium
OPENAI_COMMENTARY_EFFORT=high
OPENAI_REPORT_EFFORT=high
OPENAI_EXPERT_EFFORT=high
# Set to 0 to disable the client-side timeout cap entirely.
OPENAI_TIMEOUT_MS=90000

# ─────────────────────────────────────────────
# Sports Data
# ─────────────────────────────────────────────
# API-Sports (fixture discovery, enrichment, live polling, result resolution)
APISPORTS_API_KEY=your_api_sports_key_here
# Set to 0 to disable the client-side timeout cap entirely.
APISPORTS_TIMEOUT_MS=10000
# The Odds API (40+ European bookmakers, real-time odds verification)
THE_ODDS_API_KEY=your_the_odds_api_key_here

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
PLANNING_CRON=0 6 * * *
TIMEZONE=Europe/Athens
ANALYSIS_HOURS_BEFORE_KICKOFF=4

# ─────────────────────────────────────────────
# Analysis quality gates & test mode
# ─────────────────────────────────────────────
# TEST MODE — bypasses scheduled-status checks, Gate 5 (odds), and dedup. Set to false in production.
FORCE_ANALYSIS=false
# Minimum acceptable odds — rejects picks below this threshold (e.g., 1.50 means avoid heavy favorites)
MIN_ACCEPTABLE_ODDS=1.50
MIN_CONFIDENCE_TO_PUBLISH=6
MAX_TIPS_PER_DAY=5

# ─────────────────────────────────────────────
# Storage & logging
# ─────────────────────────────────────────────
DB_PATH=./data/posted.json
LOG_LEVEL=info
