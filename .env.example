# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GROUP_CHAT_ID=-100123456789

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_SCREENING_EFFORT=medium
OPENAI_EXPERT_EFFORT=high
OPENAI_TIMEOUT_MS=90000

# ─────────────────────────────────────────────
# Sports Data
# ─────────────────────────────────────────────
# TheSportsDB (free tier, no API key required)
THESPORTSDB_API_KEY=599407
# The Odds API (40+ European bookmakers, real-time odds verification)
THE_ODDS_API_KEY=your_the_odds_api_key_here

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
PLANNING_CRON=0 2 * * *
TIMEZONE=Europe/Athens
HOURS_BEFORE_KICKOFF=8

# ─────────────────────────────────────────────
# Analysis quality gates & test mode
# ─────────────────────────────────────────────
# TEST MODE — bypasses screening, Gate 5 (odds), and dedup. Set to false in production.
FORCE_ANALYSIS=false
# Minimum acceptable odds — rejects picks below this threshold (e.g., 1.50 means avoid heavy favorites)
MIN_ACCEPTABLE_ODDS=1.50
MIN_INTEREST_SCORE=5
MIN_CONFIDENCE_TO_PUBLISH=6
MAX_TIPS_PER_DAY=5
MAX_CANDIDATES_FROM_SCREENING=10

# ─────────────────────────────────────────────
# Storage & logging
# ─────────────────────────────────────────────
DB_PATH=./data/posted.json
LOG_LEVEL=info
