# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GROUP_CHAT_ID=-100123456789

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Model used for all analysis (supports gpt-5.4 via Responses API)
OPENAI_MODEL=gpt-5.4

# ─────────────────────────────────────────────
# Sports Data — API-Sports (api-sports.io)
# Single key covers both basketball-v1 and football-v3
# ─────────────────────────────────────────────
API_SPORTS_KEY=your_api_sports_key_here

# Basketball league IDs (api-sports basketball-v1)
# NBA = 12, EuroLeague = 120
NBA_LEAGUE_ID=12
EUROLEAGUE_LEAGUE_ID=120
BASKETBALL_SEASON=2024-25

# Football league IDs (api-sports football-v3)
# Bundesliga = 78, Serie A = 135, La Liga = 140,
# Ligue 1 = 61, Premier League = 39, Champions League = 2
FOOTBALL_LEAGUE_IDS=78,135,140,61,39,2
FOOTBALL_SEASON=2025

# ─────────────────────────────────────────────
# Scheduler — daily auto-post
# Cron expression (default: 10:00 AM UTC)
# ─────────────────────────────────────────────
DAILY_POST_CRON=0 10 * * *
TIMEZONE=UTC

# ─────────────────────────────────────────────
# Analysis quality gates
# ─────────────────────────────────────────────
# Minimum interest score (0-10) for deep analysis
MIN_INTEREST_SCORE=5
# Minimum confidence (1-10) to publish a tip
MIN_CONFIDENCE_TO_PUBLISH=6
# Max tips to publish per day
MAX_TIPS_PER_DAY=5

# ─────────────────────────────────────────────
# Database path for deduplication (stored as JSON)
# ─────────────────────────────────────────────
DB_PATH=./data/posted.json

# ─────────────────────────────────────────────
# Logging  (debug | info | warn | error)
# ─────────────────────────────────────────────
LOG_LEVEL=info
