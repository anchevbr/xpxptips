{
  "name": "ai-betting-bot",
  "version": "1.0.0",
  "description": "AI-powered betting tips Telegram bot using GPT-5.4 and the OpenAI Responses API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "test-runner": "ts-node-dev --transpile-only src/test-runner.ts",
    "test-runner-compiled": "node dist/test-runner.js",
    "test-report": "ts-node-dev --transpile-only src/test-report.ts",
    "test-halftime": "ts-node-dev --transpile-only src/test-halftime.ts",
    "test-fulltime": "ts-node-dev --transpile-only src/test-fulltime.ts"
  },
  "dependencies": {
    "openai": "^5.0.0",
    "telegraf": "^4.16.3",
    "axios": "^1.7.0",
    "axios-retry": "^4.4.0",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
